# Bitbucket Authentication — choose ONE strategy

  # Option A: Bitbucket API Token (recommended)
  # Create at: bitbucket.org → Account settings → Security → API tokens
  # Required scopes: "Repositories: Read" + "Pull requests: Read"
  BITBUCKET_EMAIL=your-atlassian-email@example.com
  BITBUCKET_TOKEN=

  # Option B: App Password (legacy)
  # Create at: bitbucket.org → Account settings → App passwords
  # Required permission: Pull requests: Read
  # BITBUCKET_USER=your-bitbucket-username
  # BITBUCKET_APP_PASSWORD=

  # AI CLI API Keys
  ANTHROPIC_API_KEY=
  OPENAI_API_KEY=
  GEMINI_API_KEY=

  # Agent CLI assignment (claude | codex | gemini)
  CLI_SECURITY=claude
  CLI_PERFORMANCE=codex
  CLI_STYLE=gemini
